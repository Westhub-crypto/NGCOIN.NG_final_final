{
  "name": "ngcoin-ultimate",
  "version": "1.0.0",
  "description": "NGCoin Ultimate Crypto Game with Admin Dashboard, TON Wallet, and Live Analytics",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "serve": "node server.js",
    "build": "echo \"No build step needed, static files served from /public\"",
    "deploy": "echo \"Deploy using Render/Heroku/Vercel or your Node host\""
  },
  "keywords": [
    "crypto",
    "game",
    "telegram",
    "admin-dashboard",
    "websocket",
    "ton-wallet",
    "live-analytics"
  ],
  "author": "Godwin Oloja",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.1",
    "jsonwebtoken": "^9.0.1",
    "pg": "^8.12.0",
    "redis": "^4.6.7",
    "ws": "^8.14.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "nodemonConfig": {
    "watch": ["server.js", "public/", "admin.html"],
    "ext": "js,html,css"
  }
}
